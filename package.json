{
  "name": "font-m3-cli",
  "version": "0.1.1",
  "description": "Search, download, and generate code for Google Fonts — Android Jetpack Compose, Material 3, and web",
  "type": "module",
  "bin": {
    "font-m3-cli": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "skills/font-m3-cli/SKILL.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target bun",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublish": "bun run build"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marwichmisi/font-m3.git"
  },
  "homepage": "https://github.com/Marwichmisi/font-m3#readme",
  "bugs": {
    "url": "https://github.com/Marwichmisi/font-m3/issues"
  },
  "keywords": [
    "google fonts",
    "jetpack compose",
    "material 3",
    "android",
    "typography",
    "font",
    "cli"
  ],
  "license": "MIT"
}
